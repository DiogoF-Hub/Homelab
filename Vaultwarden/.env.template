# =====================================================================
# Shared infrastructure
# =====================================================================
TZ=Europe/Luxembourg
SERVER_NAME=vault.example.com

# =====================================================================
# BunkerWeb: TLS / ACME
# =====================================================================
EMAIL_LETS_ENCRYPT=your@email.com

# Required for any flavor that uses the Cloudflare API for DNS-01 ACME:
# - docker-compose.cf-tunnel.yml     (CF Tunnel, DNS-01 always)
# - docker-compose.public-dns01.yml  (direct exposure, DNS-01 by choice)
# Not used by docker-compose.public-http01.yml (HTTP-01 ACME, no API token needed).
CLOUDFLARE_API_TOKEN=CHANGE_ME_TO_YOUR_CLOUDFLARE_API_TOKEN

# =====================================================================
# Cloudflare Tunnel (cloudflared), cf-tunnel stack only
# =====================================================================
CLOUD_TOKEN=CHANGE_ME_TO_YOUR_CLOUDFLARE_TUNNEL_TOKEN

# =====================================================================
# CrowdSec
# =====================================================================
# Local-only API key shared between CrowdSec LAPI (consumes via
# BOUNCER_KEY_PROXY env var → pre-creates a bouncer named `PROXY` with this
# key) and BunkerWeb's bouncer plugin (consumes via CROWDSEC_API_KEY).
# Generate fresh on any machine:
#   openssl rand -base64 48
CROWDSEC_BOUNCER_KEY=CHANGE_ME_TO_A_STRONG_RANDOM_KEY

# API key for the VPS-side firewall bouncer (see ideas.md #10). Consumed
# by CrowdSec via BOUNCER_KEY_VPS_FW_BOUNCER env var (auto-registers a
# bouncer named `VPS_FW_BOUNCER`); paste the same value into the VPS's
# /etc/crowdsec/bouncers/crowdsec-firewall-bouncer.yaml under `api_key:`.
# Generate fresh (independent from CROWDSEC_BOUNCER_KEY above):
#   openssl rand -base64 48
# Only meaningful for public-dns01 / public-http01 flavors paired with the
# edge VPS. Leave as the placeholder if not running the VPS bouncer; the
# pre-registered entry just sits unused in the LAPI's bouncers list.
CROWDSEC_VPS_BOUNCER_KEY=CHANGE_ME_TO_A_STRONG_RANDOM_KEY

# Console enrollment (get from https://app.crowdsec.net)
CROWDSEC_ENROLL_KEY=CHANGE_ME_TO_YOUR_ENROLLMENT_KEY

# =====================================================================
# Vaultwarden
# =====================================================================
# Full URL including scheme, used for email links, OIDC, CORS
DOMAIN=https://vault.example.com

# Argon2 hash of your admin panel password.
# Generate inside the container: `podman exec -it vaultwarden /vaultwarden hash`
ADMIN_TOKEN=CHANGE_ME_TO_AN_ARGON2_HASH

# =====================================================================
# Vaultwarden: SMTP (Mailjet)
# =====================================================================
SMTP_HOST=in-v3.mailjet.com
SMTP_PORT=587
SMTP_SECURITY=starttls
SMTP_USERNAME=CHANGE_ME
SMTP_PASSWORD=CHANGE_ME
SMTP_FROM=no-reply@example.com
SMTP_FROM_NAME=Vaultwarden
SMTP_TIMEOUT=15

<!--
  Pi-hole VM: Wazuh agent <localfile> blocks.

  Append these inside any <ossec_config> block in the Pi-hole VM's
  /var/ossec/etc/ossec.conf, then restart the agent:
      sudo systemctl restart wazuh-agent

  Multiple <ossec_config> blocks at the top level are valid Wazuh syntax;
  the agent merges them at load time. Easiest pattern is to drop a new
  <ossec_config> below the stock ones rather than splice into existing
  blocks.

  Prerequisite on the host: the Pi-hole compose file must bind-mount
  /var/log/pihole on the host so this path is reachable from outside the
  container. See PiHole/docker-compose.yml in this repo (the volume entry
  was added specifically for this).

  pihole.log: dnsmasq query log (the actual signal). One line per DNS
  query and reply; the manager-side custom decoder
  (manager-decoder.xml) parses query[*] lines into qtype/query/srcip.

  FTL.log: Pi-hole's own daemon log (gravity reloads, blocklist updates,
  errors). Optional but cheap to ship; useful if Pi-hole misbehaves
  unrelated to DNS resolution.
-->

<ossec_config>

  <localfile>
    <log_format>syslog</log_format>
    <location>/var/log/pihole/pihole.log</location>
  </localfile>

  <localfile>
    <log_format>syslog</log_format>
    <location>/var/log/pihole/FTL.log</location>
  </localfile>

</ossec_config>

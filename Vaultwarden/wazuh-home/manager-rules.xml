<!--
  wazuh-home (manager): rules for Vault VM DNS visibility, FTL-DB pipeline.

  Append inside /var/ossec/etc/rules/local_rules.xml on the manager.
  After editing, validate + restart:
      sudo /var/ossec/bin/wazuh-analysisd -t
      sudo systemctl restart wazuh-manager

  Goal: surface every Vault VM DNS query as a Wazuh alert with full
  metadata (qtype, query, status label) in a single event. The data
  source is the structured JSON log emitted by the sidecar at
  sidecar/pihole-ftl-tail.py, tailed by the Wazuh agent on the
  Pi-hole VM via pihole-agent.localfile.xml.

  Four-rule chain:
    - 100250 (level 0): catch-all "any vault_dns event from the
      sidecar". Archived only if logall_json is on; never alerts.
      All other rules chain off this via if_sid so the discriminator
      field check (event_type=vault_dns) doesn't have to repeat.
    - 100251 (level 3): query was actually resolved (forwarded /
      cached / etc, blocked=false in the sidecar's JSON).
    - 100252 (level 6): Pi-hole's OWN allowlist policy denied the
      query: gravity (1), regex (4), exact deny (5), CNAME variants
      (9 / 10 / 11 / 20), special domain (18). This is the real "your
      allowlist hit something unexpected" signal.
    - 100253 (level 4): upstream resolver returned a non-answer
      (NULL / NXDOMAIN / NODATA): codes 6, 7, 8, 15, 16, 17. NOT a
      Pi-hole policy hit. Most commonly this is upstream filtering
      (Cloudflare Family flagging a domain) OR a domain that legit-
      imately has no A record (e.g. cfd-features.argotunnel.com
      whose payload is in TXT, not A). Flagged at lower priority
      than 100252 so the dashboard distinguishes "your rules denied
      something" from "the upstream had no usable answer for
      whatever reason".

  Status code mapping (from the sidecar's STATUS_LABELS):
      0  unknown                                 → 100251 (blocked=false)
      1  blocked-gravity                         → 100252
      2  forwarded                               → 100251
      3  cached                                  → 100251
      4  blocked-regex                           → 100252
      5  blocked-deny-exact                      → 100252
      6  blocked-upstream-ip                     → 100253
      7  blocked-upstream-null                   → 100253
      8  blocked-upstream-nxdomain               → 100253
      9  blocked-gravity-cname                   → 100252
      10 blocked-regex-cname                     → 100252
      11 blocked-deny-cname                      → 100252
      12 retried                                 → 100251
      13 retried-ignored                         → 100251
      14 forwarded-dnssec-bogus                  → 100251
      15 blocked-external-ip-null                → 100253
      16 blocked-external-nxdomain               → 100253
      17 blocked-external-null-reply             → 100253
      18 blocked-special-domain                  → 100252
      19 cached-stale                            → 100251
      20 blocked-deny-exact-cname                → 100252

  Note on regex matching:
  Wazuh's <field name="X">value</field> match treats the value as a
  regex (PCRE2). For status_code (Pi-hole's integer cast to JSON,
  shows up as a string in Wazuh's data.* fields), the alternation
  syntax `^(1|4|5|...)$` filters by exact-match across multiple
  values. The anchors are mandatory; without them, "1" would also
  match "10", "11", etc.

  Replace 192.168.50.3 below with the actual Vault VM IP if it's
  different in your environment. (The sidecar already filters at SQL
  level to that IP before emitting events, so this rule's <srcip>
  check is belt-and-braces; it ALSO catches misconfiguration where
  the sidecar's CLIENT_FILTER got changed but the rule wasn't.)
-->
<group name="dns,pihole,vaultwarden">

  <!-- Base: every event the sidecar emits, scoped via event_type.
       Level 0 = archived (with logall_json) but no alert. -->
  <rule id="100250" level="0">
    <decoded_as>json</decoded_as>
    <field name="event_type">vault_dns</field>
    <description>Vault VM DNS event: $(query) [$(status)]</description>
  </rule>

  <!-- Resolved query: the Vault VM got a real DNS answer
       (forwarded / cached / etc; status codes 0, 2, 3, 12, 13, 14, 19).
       blocked=false in the JSON. -->
  <rule id="100251" level="3">
    <if_sid>100250</if_sid>
    <srcip>192.168.50.3</srcip>
    <field name="blocked">false</field>
    <description>Vault VM DNS resolved: $(query) [$(status)]</description>
  </rule>

  <!-- Pi-hole's own policy denied the query (gravity, regex, exact
       deny, CNAME-cloak variants, special domain). This is the real
       "allowlist hit something unexpected" alert. -->
  <rule id="100252" level="6">
    <if_sid>100250</if_sid>
    <srcip>192.168.50.3</srcip>
    <field name="status_code" type="pcre2">^(1|4|5|9|10|11|18|20)$</field>
    <description>Vault VM DNS BLOCKED by Pi-hole policy: $(query) [$(status)]</description>
  </rule>

  <!-- Upstream resolver returned a non-answer (NULL / NXDOMAIN /
       NODATA; status codes 6, 7, 8, 15, 16, 17). NOT a Pi-hole
       policy hit; this is upstream filtering (Cloudflare Family) or
       a domain that legitimately has no A record. Lower priority. -->
  <rule id="100253" level="4">
    <if_sid>100250</if_sid>
    <srcip>192.168.50.3</srcip>
    <field name="status_code" type="pcre2">^(6|7|8|15|16|17)$</field>
    <description>Vault VM DNS no-answer (upstream): $(query) [$(status)]</description>
  </rule>

</group>

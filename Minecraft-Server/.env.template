# RCON password for in-game admin (the RCON port is NOT exposed to the host).
RCON_PASSWORD=

# CurseForge developer API key. Only needed if you switch the minecraft service
# to TYPE: AUTO_CURSEFORGE (downloads a public modpack server pack directly).
# Generate at https://console.curseforge.com/#/api-keys
# Leave empty for the default TYPE: FABRIC + manual mods/ workflow.
CF_API_KEY=
